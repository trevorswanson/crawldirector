// DCC Campaign Builder — Prisma schema.
// M2 scope: identity, tenancy, entity canon, and the review/provenance pipeline
// that all canon writes route through.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ───────────── Roles ─────────────
// Per docs/02-architecture.md: tenancy boundary is the Campaign; a Membership
// maps (user, campaign) -> role. A user may hold different roles across
// campaigns.
enum Role {
  OWNER
  CO_DM
  PLAYER
}

enum EntityType {
  CRAWLER
  NPC
  SPECIES
  CLASS
  PARTY
  GUILD
  FLOOR
  NEIGHBORHOOD
  LOCATION
  BOSS
  MOB_TYPE
  FACTION
  ORGANIZATION
  SPONSOR
  SHOW
  SYSTEM_AI
  ITEM
  SKILL
  SPELL
  ACHIEVEMENT
  TITLE
  SYSTEM_MESSAGE
  DEITY
}

enum CanonStatus {
  DRAFT
  PENDING
  CANON
  REJECTED
  ARCHIVED
}

enum Visibility {
  DM_ONLY
  SHARED_WITH_PLAYERS
  PLAYER_FACING
}

enum ChangeSource {
  DM
  AI
  PLAYER_SUGGESTION
  IMPORT
}

enum ChangeSetStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIALLY_APPLIED
  SUPERSEDED
}

enum OpKind {
  CREATE_ENTITY
  UPDATE_ENTITY
  DELETE_ENTITY
  CREATE_RELATIONSHIP
  UPDATE_RELATIONSHIP
  DELETE_RELATIONSHIP
  CREATE_EVENT
  UPDATE_EVENT
  APPLY_EVENT_EFFECTS
}

enum OpDecision {
  PENDING
  ACCEPTED
  EDITED
  REJECTED
}

// ───────────── Identity & Auth.js adapter ─────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // Credentials sign-in: bcrypt hash. Null for OAuth-only users.
  passwordHash  String?

  accounts        Account[]
  sessions        Session[]
  memberships     Membership[]
  // Campaigns this user owns (also represented by an OWNER membership).
  ownedCampaigns  Campaign[]   @relation("OwnedCampaigns")
  createdEntities Entity[]     @relation("CreatedEntities")
  authoredChangeSets ChangeSet[] @relation("AuthoredChangeSets")
  reviewedChangeSets ChangeSet[] @relation("ReviewedChangeSets")
  provenanceRows Provenance[] @relation("ActorProvenance")
  auditLogs      AuditLog[]   @relation("ActorAuditLogs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────── Tenancy ─────────────
model Campaign {
  id         String  @id @default(cuid())
  name       String
  summary    String?
  // Tone / canon constraints surfaced to AI generators in later milestones.
  styleGuide String?

  ownerId String
  owner   User   @relation("OwnedCampaigns", fields: [ownerId], references: [id])

  members  Membership[]
  entities Entity[]
  changeSets ChangeSet[]
  provenance Provenance[]
  auditLogs  AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Membership {
  id         String @id @default(cuid())
  userId     String
  campaignId String
  role       Role

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, campaignId])
  @@index([campaignId])
}

// ───────────── Entity core ─────────────
model Entity {
  id           String      @id @default(cuid())
  campaignId   String
  type         EntityType
  name         String
  summary      String?
  description  String?
  status       CanonStatus @default(CANON)
  visibility   Visibility  @default(DM_ONLY)
  source       ChangeSource @default(DM)
  data         Json        @default("{}")
  customFields Json        @default("{}")
  tags         String[]    @default([])
  version      Int         @default(1)
  locked       Boolean     @default(false)
  lockedFields String[]    @default([])
  isStub       Boolean     @default(false)
  agentEnabled Boolean     @default(false)

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?    @relation("CreatedEntities", fields: [createdById], references: [id], onDelete: SetNull)
  crawler     Crawler?
  provenance  Provenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId, type])
  @@index([campaignId, status])
  @@index([campaignId, source])
  @@index([campaignId, name])
}

model Crawler {
  id            String  @id
  entity        Entity  @relation(fields: [id], references: [id], onDelete: Cascade)
  realName      String?
  crawlerNo     String?
  level         Int     @default(1)
  stats         Json    @default("{}")
  hp            Int?
  mp            Int?
  gold          Int     @default(0)
  viewCount     BigInt  @default(0)
  followerCount BigInt  @default(0)
  favoriteCount BigInt  @default(0)
  killCount     Int     @default(0)
  isAlive       Boolean @default(true)
  currentFloor  Int?
}

// ───────────── Review pipeline ─────────────
model ChangeSet {
  id            String          @id @default(cuid())
  campaignId    String
  source        ChangeSource
  title         String
  summary       String?
  status        ChangeSetStatus @default(PENDING)
  actorUserId   String?
  providerId    String?
  model         String?
  promptId      String?
  promptVersion String?
  runId         String?
  baseVersions  Json            @default("{}")
  operations    ChangeOperation[]
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  provenance    Provenance[]

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User?    @relation("AuthoredChangeSets", fields: [actorUserId], references: [id], onDelete: SetNull)
  reviewer User?    @relation("ReviewedChangeSets", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId, status])
  @@index([actorUserId])
}

model ChangeOperation {
  id            String     @id @default(cuid())
  changeSetId   String
  op            OpKind
  targetType    String
  targetId      String?
  patch         Json
  editedPatch   Json?
  decision      OpDecision @default(PENDING)
  blockedByLock Boolean    @default(false)
  isStale       Boolean    @default(false)

  changeSet ChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@index([changeSetId])
  @@index([targetType, targetId])
}

model Provenance {
  id                String       @id @default(cuid())
  campaignId        String
  entityId          String?
  relationshipId    String?
  eventId           String?
  personaSnapshotId String?
  changeSetId       String
  source            ChangeSource
  field             String?
  actorUserId       String?
  providerId        String?
  model             String?
  promptId          String?
  runId             String?

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  entity    Entity?   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  changeSet ChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)
  actor     User?     @relation("ActorProvenance", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entityId])
  @@index([changeSetId])
}

model AuditLog {
  id          String @id @default(cuid())
  campaignId  String
  actorUserId String
  action      String
  targetType  String
  targetId    String
  detail      Json   @default("{}")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User     @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([targetType, targetId])
}
