// DCC Campaign Builder — Prisma schema.
// M2 scope: identity, tenancy, entity canon, and the review/provenance pipeline
// that all canon writes route through.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ───────────── Roles ─────────────
// Per docs/02-architecture.md: tenancy boundary is the Campaign; a Membership
// maps (user, campaign) -> role. A user may hold different roles across
// campaigns.
enum Role {
  OWNER
  CO_DM
  PLAYER
}

enum EntityType {
  CRAWLER
  NPC
  SPECIES
  CLASS
  PARTY
  GUILD
  FLOOR
  NEIGHBORHOOD
  LOCATION
  BOSS
  MOB_TYPE
  FACTION
  ORGANIZATION
  SPONSOR
  SHOW
  SYSTEM_AI
  ITEM
  ITEM_TYPE
  SKILL
  SPELL
  ACHIEVEMENT
  TITLE
  SYSTEM_MESSAGE
  DEITY
}

enum CanonStatus {
  DRAFT
  PENDING
  CANON
  REJECTED
  ARCHIVED
}

enum Visibility {
  DM_ONLY
  PLAYER_VISIBLE
}

enum ChangeSource {
  DM
  AI
  PLAYER_SUGGESTION
  IMPORT
  MIGRATION
}

enum ChangeSetStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIALLY_APPLIED
  SUPERSEDED
}

enum OpKind {
  CREATE_ENTITY
  UPDATE_ENTITY
  DELETE_ENTITY
  CREATE_RELATIONSHIP
  UPDATE_RELATIONSHIP
  DELETE_RELATIONSHIP
  CREATE_EVENT
  UPDATE_EVENT
  CREATE_EVENT_CAUSALITY
  DELETE_EVENT_CAUSALITY
  APPLY_EVENT_EFFECTS
}

enum OpDecision {
  PENDING
  ACCEPTED
  EDITED
  REJECTED
}

// How an entity participates in an Event (docs/01-domain-model.md). Like
// relationship types, this is a semantic label — any entity can take any role.
enum EventParticipantRole {
  ACTOR
  TARGET
  WITNESS
  LOCATION
  AFFECTED
}

// Typed, any-to-any relationship edges (docs/01-domain-model.md). The type is a
// semantic label, never a structural constraint — both endpoints FK to the
// generic Entity, so any type can relate to any other.
enum RelationshipType {
  MEMBER_OF
  LEADS
  SPONSORS
  EMPLOYS
  ALLIED_WITH
  RIVAL_OF
  AT_WAR_WITH
  PARENT_ORG_OF
  USED_BY
  MANIPULATES
  CONTROLS
  DEFIES
  ALLY_OF
  ENEMY_OF
  MENTOR_OF
  MANAGES
  LOVES
  FAMILY_OF
  OWES
  LOCATED_ON
  PART_OF
  CONTAINS
  BOSS_OF
  SPAWNS_ON
  HAS_CLASS
  HAS_SPECIES
  OWNS_ITEM
  KNOWS_SKILL
  EARNED_ACHIEVEMENT
  HOLDS_TITLE
  APPEARS_ON
  KNOWS_ABOUT
  BETRAYED
  KILLED
  SAVED
}

// ───────────── Knowledge / reveals (fog of war) ─────────────
// Canon visibility is not only global. A DM can reveal a specific entity (and,
// later, a field/relationship/event/fact) to one actor entity (NPC, crawler,
// party, faction) or player membership without sharing it campaign-wide. These
// grants power both the player "known world" projection (M7) and in-character
// agent context (M11). See docs/09-data-schema.md and docs/06-entity-agents.md.
enum KnowledgeTargetType {
  ENTITY
  ENTITY_FIELD
  RELATIONSHIP
  EVENT
  FACT
}

enum KnowledgeRecipientType {
  ENTITY
  MEMBERSHIP
}

// ───────────── Identity & Auth.js adapter ─────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // Credentials sign-in: bcrypt hash. Null for OAuth-only users.
  passwordHash  String?

  accounts           Account[]
  sessions           Session[]
  memberships        Membership[]
  // Campaigns this user owns (also represented by an OWNER membership).
  ownedCampaigns     Campaign[]   @relation("OwnedCampaigns")
  createdEntities    Entity[]     @relation("CreatedEntities")
  authoredChangeSets ChangeSet[]  @relation("AuthoredChangeSets")
  reviewedChangeSets ChangeSet[]  @relation("ReviewedChangeSets")
  provenanceRows     Provenance[] @relation("ActorProvenance")
  auditLogs          AuditLog[]   @relation("ActorAuditLogs")
  createdAiKeys      AiKey[]      @relation("CreatedAiKeys")
  aiUsage            AiUsage[]    @relation("RequestedAiUsage")
  createdJobs        Job[]        @relation("CreatedJobs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────── Tenancy ─────────────
model Campaign {
  id         String  @id @default(cuid())
  name       String
  summary    String?
  // Tone / canon constraints surfaced to AI generators in later milestones.
  styleGuide String?

  // Optional DM-set ceiling (USD) on total estimated AI spend for this campaign.
  // Null = no cap. Enforced against the sum of priced AiUsage rows before a
  // generation runs (M4 — docs/04-ai-integration.md).
  spendCapUsd Float?

  ownerId String
  owner   User   @relation("OwnedCampaigns", fields: [ownerId], references: [id])

  // The floor the crawl is currently on — a DM-chosen FLOOR entity. Drives the
  // timeline's "ON AIR" / current-floor styling (docs/adr/0005). Nulled if the
  // referenced entity is deleted.
  currentFloorId String?
  currentFloor   Entity? @relation("CampaignCurrentFloor", fields: [currentFloorId], references: [id], onDelete: SetNull)

  members          Membership[]
  entities         Entity[]
  relationships    Relationship[]
  events           Event[]
  eventCausalities EventCausality[]
  changeSets       ChangeSet[]
  provenance       Provenance[]
  auditLogs        AuditLog[]
  knowledgeGrants  KnowledgeGrant[]
  aiKeys           AiKey[]
  aiUsage          AiUsage[]
  jobs             Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Membership {
  id         String @id @default(cuid())
  userId     String
  campaignId String
  role       Role

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, campaignId])
  @@index([campaignId])
}

// ───────────── Entity core ─────────────
model Entity {
  id           String       @id @default(cuid())
  campaignId   String
  type         EntityType
  name         String
  summary      String?
  description  String?
  status       CanonStatus  @default(CANON)
  visibility   Visibility   @default(DM_ONLY)
  source       ChangeSource @default(DM)
  data         Json         @default("{}")
  customFields Json         @default("{}")
  tags         String[]     @default([])
  version      Int          @default(1)
  locked       Boolean      @default(false)
  lockedFields String[]     @default([])
  isStub       Boolean      @default(false)
  agentEnabled Boolean      @default(false)

  campaign       Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?              @relation("CreatedEntities", fields: [createdById], references: [id], onDelete: SetNull)
  // Campaigns pointing at this entity as their current floor (FLOOR entities).
  currentFloorOf Campaign[]         @relation("CampaignCurrentFloor")
  crawler        Crawler?
  outEdges       Relationship[]     @relation("SourceEntity")
  inEdges        Relationship[]     @relation("TargetEntity")
  eventRoles     EventParticipant[]
  provenance     Provenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId, type])
  @@index([campaignId, status])
  @@index([campaignId, source])
  @@index([campaignId, name])
}

model Crawler {
  id            String  @id
  entity        Entity  @relation(fields: [id], references: [id], onDelete: Cascade)
  realName      String?
  crawlerNo     String?
  level         Int     @default(1)
  stats         Json    @default("{}")
  hp            Int?
  mp            Int?
  gold          Int     @default(0)
  viewCount     BigInt  @default(0)
  followerCount BigInt  @default(0)
  favoriteCount BigInt  @default(0)
  killCount     Int     @default(0)
  isAlive       Boolean @default(true)
  currentFloor  Int?
}

// ───────────── Relationships (typed, any-to-any edges) ─────────────
// Both endpoints FK to the generic Entity. Reviewable + lockable like any canon
// (docs/03-review-pipeline.md): writes route through the review service, which
// records provenance. Soft-archived (status ARCHIVED), never hard-deleted.
model Relationship {
  id          String           @id @default(cuid())
  campaignId  String
  type        RelationshipType
  sourceId    String
  targetId    String
  disposition Int?
  sinceDay    Int?
  untilDay    Int?
  attributes  Json             @default("{}")
  notes       String?
  secret      Boolean          @default(false)
  source      ChangeSource     @default(DM)
  status      CanonStatus      @default(CANON)
  locked      Boolean          @default(false)
  version     Int              @default(1)

  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sourceEntity Entity       @relation("SourceEntity", fields: [sourceId], references: [id], onDelete: Cascade)
  targetEntity Entity       @relation("TargetEntity", fields: [targetId], references: [id], onDelete: Cascade)
  provenance   Provenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId, sourceId])
  @@index([campaignId, targetId])
  @@index([campaignId, type])
  @@index([campaignId, type, sinceDay, untilDay])
  @@index([campaignId, status])
}

// ───────────── Events & causality (the "why") ─────────────
// Something that happened (or is scheduled): a death, a sponsorship signed, a
// Floor-9 battle. Reviewable + lockable like any canon; writes route through the
// review service, which records provenance. Soft-archived, never hard-deleted.
// In-game time is a flexible structure ({ floor?, dayInFloor?, absoluteDay?,
// label? }) — DCC time is irregular, so we never force calendar dates
// (docs/01-domain-model.md). Order is mechanical and derived, never authored: a
// coarse `orderKey` (the floor) for cheap DB sorting, plus a fractional `rank`
// (a lexicographically-sortable string, see src/lib/rank.ts) that gives a
// stable, DM-controllable order *within* a floor. The timeline sorts by
// `(orderKey, rank)`; neither is a reviewable field (ADR 0004).
model Event {
  id          String       @id @default(cuid())
  campaignId  String
  title       String
  summary     String?
  description String?
  inGameTime  Json         @default("{}")
  orderKey    Int          @default(0)
  rank        String       @default("a0")
  // Structured deltas this event can apply to entity state on approval
  // (docs/01-domain-model.md). Each entry:
  //   { id, kind: "ADJUST_STAT"|"SET_STAT"|"SET_ALIVE", targetEntityId,
  //     stat?, delta?, valueNumber?, value?, note?, applied,
  //     appliedChangeSetId?, pendingChangeSetId?, pendingOperationId?,
  //     reviewStatus? }. Submitting them creates a pending APPLY_EVENT_EFFECTS
  // operation; approval applies the entity write atomically through the review
  // pipeline. DM-only (never projected to players). Generic-entity /
  // disposition / PERSONA_SHIFT effects are follow-ups.
  effects     Json         @default("[]")
  secret      Boolean      @default(false)
  source      ChangeSource @default(DM)
  status      CanonStatus  @default(CANON)
  locked      Boolean      @default(false)
  version     Int          @default(1)

  campaign     Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participants EventParticipant[]
  causedBy     EventCausality[]   @relation("Effect")
  causes       EventCausality[]   @relation("Cause")
  provenance   Provenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId, status])
  @@index([campaignId, orderKey, rank])
}

// Typed link between an Event and an Entity (any-to-any: any entity can hold any
// role). Cascades with both endpoints so archived events keep their participant
// rows but a hard-deleted entity drops its participations.
model EventParticipant {
  id       String               @id @default(cuid())
  eventId  String
  entityId String
  role     EventParticipantRole @default(ACTOR)

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([eventId, entityId, role])
  @@index([eventId])
  @@index([entityId])
}

// Directed cause -> effect edge between two Events. These form a DAG in service
// logic so DMs can traverse why something happened and what it caused.
model EventCausality {
  id         String       @id @default(cuid())
  campaignId String
  causeId    String
  effectId   String
  weight     Int?
  note       String?
  source     ChangeSource @default(DM)
  status     CanonStatus  @default(CANON)
  locked     Boolean      @default(false)
  version    Int          @default(1)

  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  cause      Event        @relation("Cause", fields: [causeId], references: [id], onDelete: Cascade)
  effect     Event        @relation("Effect", fields: [effectId], references: [id], onDelete: Cascade)
  provenance Provenance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([causeId, effectId])
  @@index([campaignId, status])
  @@index([causeId])
  @@index([effectId])
}

// ───────────── Review pipeline ─────────────
model ChangeSet {
  id            String            @id @default(cuid())
  campaignId    String
  source        ChangeSource
  title         String
  summary       String?
  status        ChangeSetStatus   @default(PENDING)
  actorUserId   String?
  providerId    String?
  model         String?
  promptId      String?
  promptVersion String?
  runId         String?
  baseVersions  Json              @default("{}")
  operations    ChangeOperation[]
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNotes   String?
  provenance    Provenance[]

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User?    @relation("AuthoredChangeSets", fields: [actorUserId], references: [id], onDelete: SetNull)
  reviewer User?    @relation("ReviewedChangeSets", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId, status])
  @@index([actorUserId])
}

model ChangeOperation {
  id             String     @id @default(cuid())
  changeSetId    String
  op             OpKind
  targetType     String
  targetId       String?
  patch          Json
  editedPatch    Json?
  fieldDecisions Json       @default("{}")
  decision       OpDecision @default(PENDING)
  blockedByLock  Boolean    @default(false)
  isStale        Boolean    @default(false)

  changeSet ChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@index([changeSetId])
  @@index([targetType, targetId])
}

model Provenance {
  id                String       @id @default(cuid())
  campaignId        String
  entityId          String?
  relationshipId    String?
  eventId           String?
  eventCausalityId  String?
  personaSnapshotId String?
  changeSetId       String
  source            ChangeSource
  field             String?
  actorUserId       String?
  providerId        String?
  model             String?
  promptId          String?
  runId             String?

  campaign       Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  entity         Entity?         @relation(fields: [entityId], references: [id], onDelete: Cascade)
  relationship   Relationship?   @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  event          Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventCausality EventCausality? @relation(fields: [eventCausalityId], references: [id], onDelete: Cascade)
  changeSet      ChangeSet       @relation(fields: [changeSetId], references: [id], onDelete: Cascade)
  actor          User?           @relation("ActorProvenance", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entityId])
  @@index([relationshipId])
  @@index([eventId])
  @@index([eventCausalityId])
  @@index([changeSetId])
}

model AuditLog {
  id          String @id @default(cuid())
  campaignId  String
  actorUserId String
  action      String
  targetType  String
  targetId    String
  detail      Json   @default("{}")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actor    User     @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([targetType, targetId])
}

// A private knowledge grant: actor/recipient "knows" a target (entity/field/etc.)
// without it being campaign-wide visible. Reveals/revokes are deliberate, audited
// DM actions (AuditLog REVEAL/REVOKE) — not content change sets — like locks.
// `targetId`/`recipientId` are polymorphic (an Entity id, Relationship id,
// Membership id, …) keyed by their *Type, so they are not FK columns. Revoke is
// soft (revokedAt set) so the reveal history is preserved. A grant is "active"
// when revokedAt is null and it has not expired.
model KnowledgeGrant {
  id            String                 @id @default(cuid())
  campaignId    String
  targetType    KnowledgeTargetType
  targetId      String // Entity.id, Relationship.id, Event.id, … (per targetType)
  field         String? // for ENTITY_FIELD / field-level reveals
  factKey       String? // optional stable key for derived/ad-hoc FACT reveals
  recipientType KnowledgeRecipientType
  recipientId   String // Entity.id (actor) or Membership.id (per recipientType)
  sourceEventId String? // optional event/session context that revealed it
  revealedById  String
  revealedAt    DateTime               @default(now())
  expiresAt     DateTime?
  notes         String?
  revokedAt     DateTime?
  revokedById   String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, recipientType, recipientId])
  @@index([campaignId, targetType, targetId])
}

// ───────────── Async job queue (M4 — docs/04-ai-integration.md §"Async / batching") ─────────────
enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum JobKind {
  BULK_FLESH
  LORE_SEED
  EMBED_SEARCH_DOCS
  MIGRATE_ENTITY_DATA
}

// Async work queue (M4 — docs/04-ai-integration.md §"Async / batching"): long
// or bulk generation runs execute off the request path in the worker
// (scripts/worker.ts). Jobs only ever *file proposals* through the existing
// services — a job never writes canon directly (invariant #1) and its payload
// carries no secret (invariant #6).
model Job {
  id          String    @id @default(cuid())
  campaignId  String
  createdById String
  kind        JobKind
  status      JobStatus @default(QUEUED)
  // Handler input (e.g. { entityIds: [...] } for BULK_FLESH). No secrets.
  payload     Json
  // Handler output on success (e.g. fleshOutEntities' outcome summary).
  result      Json?
  // Safe message on failure (ServiceError text only — never raw provider text).
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(1)
  runAfter    DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User     @relation("CreatedJobs", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, runAfter])
  @@index([campaignId, createdAt])
}

// ───────────── AI config ─────────────
// A DM's bring-your-own provider API key, encrypted at rest (M4 — docs/04-ai-
// integration.md). `ciphertext` is AES-256-GCM envelope-encrypted key material
// (src/server/crypto.ts) and is NEVER returned to the client, logged, or placed
// in provenance (invariant #6); it is decrypted only at the server-side provider
// call. `lastFour` is a non-secret display hint (the key's last four characters,
// like a card) so the DM can tell which key is configured without revealing it.
// One key per (campaign, provider).
model AiKey {
  id                  String  @id @default(cuid())
  campaignId          String
  providerId          String // matches an id in src/lib/ai/providers.ts (e.g. "anthropic")
  ciphertext          String // AES-256-GCM envelope-encrypted API key — never leaves the server
  lastFour            String // non-secret hint: the key's last 4 chars
  baseUrl             String? // OpenAI-compatible endpoint (self-hosted / proxy); non-secret config
  model               String? // optional per-key chat model override; falls back to the provider default
  // Optional bring-your-own embedding model for semantic search (M5 — docs/07-
  // search-retrieval.md). OpenAI-compatible providers only. Null → the provider's
  // embedding default (OpenAI) or no semantic search (custom endpoint).
  embeddingModel      String?
  // Optional vector dimension for the embedding model. Null keeps the provider
  // default (1536 for OpenAI's default embedder and legacy custom configs).
  // Non-secret config; SearchDoc stores the actual dimension used per row.
  embeddingDimensions Int?
  // Optional DM-supplied price (USD per 1M tokens) for usage/cost estimation. When
  // both are set they override the built-in price table (src/lib/ai/pricing.ts) —
  // the only way to cost a self-hosted/proxy model the table doesn't know. Non-secret.
  inputPerMTokUsd     Float?
  outputPerMTokUsd    Float?
  createdById         String

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User     @relation("CreatedAiKeys", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, providerId])
  @@index([campaignId])
}

// One AI generation's token usage + estimated cost (M4 — docs/04-ai-
// integration.md). Written after a successful provider call so the DM can see
// what generation is costing and so spend caps can be enforced. Tokens are
// always recorded; `estimatedCostUsd` is null when the model's price is unknown
// (a custom endpoint or an unpriced model) — we never invent a number. This is a
// cost/usage record, NOT provenance, and it carries no secret: the API key is
// never referenced here (invariant #6).
model AiUsage {
  id          String  @id @default(cuid())
  campaignId  String
  // Who triggered the run, and what produced it.
  createdById String
  providerId  String // matches an id in src/lib/ai/providers.ts
  model       String
  generatorId String // the generator's prompt id (e.g. "flesh-entity")
  // The PENDING change set this run produced, if any. Plain id (no FK relation):
  // a usage record is an audit trail that should outlive a deleted change set.
  changeSetId String?

  inputTokens         Int
  outputTokens        Int
  cacheReadTokens     Int @default(0)
  cacheCreationTokens Int @default(0)

  // Estimated USD cost from src/lib/ai/pricing.ts. Null when the model is
  // unpriced — the tokens above are still authoritative.
  estimatedCostUsd Float?

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User     @relation("RequestedAiUsage", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([campaignId, createdAt])
}

// ───────────── Search & retrieval (M5 — docs/07-search-retrieval.md) ─────────────
// Denormalized, campaign-scoped search index over canon. Derived data:
// regenerable from canon, never part of provenance, never shown to players
// except through the visibility mirror below. `content` is the searchable text
// (name + summary + salient fields). `searchVector` is a database-generated
// Postgres `tsvector` with a GIN index for keyword/full-text retrieval; Prisma
// marks it Unsupported so the client never writes it directly. `embedding` is a
// pgvector semantic embedding of `content` (M5 slice 4a, hybrid search);
// populated asynchronously by the embedding service through the Job worker and
// written via raw SQL, so it is nullable and the typed client never sets it.
// `embeddingModel` and `embeddingDimensions` record which embedder produced the
// vector, so hybrid retrieval only compares same-model/same-shape rows. Slice 4c
// adds a raw-SQL HNSW cosine expression index for the default 1536-dimensional
// path (`SearchDoc_embedding_hnsw_1536_idx`); Prisma cannot represent pgvector's
// index type in `@@index`, so the index intentionally lives only in the
// migration. No FK to the source: `targetId` is polymorphic and a SearchDoc is a
// regenerable mirror that should outlive churn in canon.
model SearchDoc {
  id                  String                   @id @default(cuid())
  campaignId          String
  targetType          String // ENTITY | RELATIONSHIP | EVENT
  targetId            String
  content             String // denormalized name + summary + salient fields
  // Generated from content; GIN-indexed in migration.
  searchVector        Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, content)"))
  // Semantic layer (M5 slice 4a+4c). Written via raw SQL; null = not yet embedded.
  embedding           Unsupported("vector")?
  embeddingModel      String?
  embeddingDimensions Int?
  visibility          Visibility               @default(DM_ONLY) // mirror of source, for scoped retrieval
  updatedAt           DateTime                 @updatedAt

  @@unique([targetType, targetId])
  @@index([campaignId, targetType])
  @@index([searchVector], type: Gin, map: "SearchDoc_searchVector_idx")
}
