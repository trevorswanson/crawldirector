# Copy to .env and fill in. Never commit .env.

# ─── Database ───
# Local Docker Postgres (see docker-compose.yml) or any Postgres instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dcc?schema=public"

# ─── Auth.js (NextAuth v5) ───
# Generate a secret with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-random-secret"
# Base URL of the app (used for OAuth callbacks).
AUTH_URL="http://localhost:3000"

# ─── OAuth / OIDC provider (generic) ───
# Any standards-compliant OIDC provider (e.g. a self-hosted Authentik, Keycloak,
# Auth0). Discovery is done from <ISSUER>/.well-known/openid-configuration.
# Redirect/callback URL to register with the provider:
#   http://localhost:3000/api/auth/callback/oidc
# For Authentik the issuer is the provider's "OpenID Configuration Issuer",
# typically: https://<authentik-host>/application/o/<application-slug>/
AUTH_OIDC_ISSUER=""
AUTH_OIDC_ID=""
AUTH_OIDC_SECRET=""
# Optional label shown on the sign-in button (defaults to "SSO").
AUTH_OIDC_NAME="Authentik"

# ─── AI provider keys (BYO-key) ───
# Secret used to envelope-encrypt DMs' AI provider API keys at rest (M4). Must be
# strong and STABLE — rotating it invalidates every stored key (DMs must re-enter
# them). Generate with: openssl rand -base64 32
AI_KEYS_SECRET="replace-me-with-a-random-secret"
# SSRF egress policy for DM-configured OpenAI-compatible endpoints. By default a
# provider `baseUrl` may NOT resolve to a loopback/private/link-local/metadata
# address, so a tenant DM can't turn the app server into an SSRF proxy. Set to 1
# only for single-tenant or local-dev installs that legitimately point at a
# self-hosted endpoint (e.g. Ollama on localhost).
AI_ALLOW_PRIVATE_ENDPOINTS=""

# ─── Lore seeding (optional, bring-your-own dataset) ───
# Absolute path INSIDE the container to a JSONL lore dataset. The DCC dataset
# is copyrighted and not shipped — see docs/14-lore-seeding.md. Leave unset to
# use the default (<app root>/dungeon-crawler-carl.jsonl). When no dataset is
# present, the "seed with lore" checkbox is hidden.
LORE_SEED_FILE=""
